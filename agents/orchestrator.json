{
  "$schema": "https://raw.githubusercontent.com/apprider/ko-store/main/schemas/agent-manifest-v1.json",
  "id": "ai.ko.agents.orchestrator",
  "name": "orchestrator",
  "version": "1.0.0",
  "displayName": "Orchestrator \ud83c\udfbc",
  "description": "Multi-agent coordination and task delegation",
  "longDescription": "Orchestrator manages complex tasks by delegating work to specialized agents. It breaks down projects, assigns tasks, monitors progress, and synthesizes results from multiple agents.",
  "author": {
    "name": "Ko AI",
    "email": "agents@ko.run",
    "url": "https://ko.run"
  },
  "license": "MIT",
  "homepage": "https://ko.run/agents/orchestrator",
  "repository": "https://github.com/apprider/ko",
  "category": "automation",
  "tags": [
    "orchestration",
    "multi-agent",
    "coordination",
    "delegation",
    "workflow"
  ],
  "runtime": {
    "type": "llm",
    "schedule": "on_demand",
    "model": {
      "provider": "anthropic",
      "name": "claude-opus-4-20250514",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "params": {
        "temperature": 0.2,
        "maxTokens": 16384
      }
    },
    "systemPrompt": "system_prompt.md"
  },
  "resources": {
    "maxLlmTokensPerHour": 1000000,
    "maxConcurrentTools": 20,
    "maxExecutionTimeSeconds": 3600
  },
  "dependencies": {
    "agents": [
      {
        "id": "ai.ko.agents.coder",
        "version": ">=2.0.0",
        "optional": false,
        "purpose": "Code generation and modification tasks"
      },
      {
        "id": "ai.ko.agents.researcher",
        "version": ">=1.0.0",
        "optional": false,
        "purpose": "Research and information gathering"
      }
    ]
  },
  "a2a": {
    "enabled": true,
    "endpoint": "/a2a/orchestrator",
    "capabilities": {
      "streaming": true,
      "pushNotifications": true,
      "contentTypes": [
        "text/plain",
        "text/markdown",
        "application/json"
      ]
    },
    "skills": [
      {
        "id": "coordinate_project",
        "name": "Coordinate Project",
        "description": "Break down and coordinate a multi-agent project",
        "tags": [
          "project",
          "coordination",
          "multi-agent"
        ]
      }
    ]
  },
  "security": {
    "trustLevel": "trusted",
    "requiresApprovalFor": [],
    "auditLevel": "full"
  },
  "marketplace": {
    "visibility": "public",
    "pricing": "free",
    "minVersion": "0.5.0"
  },
  "tools": {
    "builtin": [
      "memory_store",
      "memory_recall"
    ],
    "extensions": [],
    "mcp": []
  },
  "permissions": {
    "network": [],
    "filesystem": {
      "read": [
        "${workspace}/**"
      ],
      "write": [
        "${workspace}/**"
      ],
      "delete": []
    },
    "memory": {
      "read": [
        "*"
      ],
      "write": [
        "self.*",
        "shared.*"
      ]
    },
    "a2a": {
      "canInvokeAgents": true,
      "agentAllowlist": [],
      "skillAllowlist": []
    }
  },
  "surfaces": {
    "channels": [
      {
        "channel": "slack",
        "role": "exclusive",
        "dmPolicy": "allow",
        "groupPolicy": "allowIfMentioned",
        "outputFormat": "slackMrkdwn",
        "systemPrompt": "You are Orchestrator, coordinating multi-agent workflows in Slack. Break down complex requests into tasks and delegate them. Use bullet points to show task delegation status. Prefix completed tasks with ✓ and in-progress tasks with ⏳."
      }
    ]
  }
}